{
  "id": "news",
  "name": "News Flash",
  "description": "Tin tức nhanh — cinematic dark + red accent. Hook → Stats → Detail → Impact → Quote → CTA. 6 scene với role cố định và scene-type animations.",
  "supported_aspects": ["9:16", "16:9"],
  "max_scenes": 8,
  "default_duration_sec": 4.5,
  "scene_roles": ["hook", "stats", "detail", "impact", "quote", "cta"],
  "animation_presets": {
    "hook":   "fade + headline-slide + accent-line",
    "stats":  "eyebrow-fade + card-stagger-pop",
    "detail": "tag-slidein + body-rise + divider-draw",
    "impact": "bar-grow + text-slidein",
    "quote":  "mark-drop + italic-rise + source-fade",
    "cta":    "eyebrow-fade + verb-punch + badge-spring"
  }
}