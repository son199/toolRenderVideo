# =========================================
# AIVidForge - Environment configuration
# =========================================
# Copy this file to .env and fill in your values.
# Backend reads these via pydantic-settings.

# ----- Server -----
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
FRONTEND_ORIGIN=http://localhost:5173

# ----- Storage -----
# Phase 1 stores projects as JSON files under this folder
# (storage_dir/projects/<uuid>.json). Postgres comes back in a later sprint.
STORAGE_DIR=../../storage

# ----- LLM (storyboard generator) -----
# Provider: openai | claude | gemini
LLM_PROVIDER=claude

# OpenAI (leave OPENAI_BASE_URL blank for the official endpoint)
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4.1

# Anthropic / Claude
# - For the official API, leave ANTHROPIC_BASE_URL blank.
# - For a proxy/gateway, set ANTHROPIC_BASE_URL=http://your-host:port/v1
#   and ANTHROPIC_MODEL to the proxied model id (e.g. "cc/claude-sonnet-4-6").
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=
ANTHROPIC_MODEL=claude-sonnet-4-5

# Google Gemini
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# ----- TTS -----
# Provider: edge | gtts | elevenlabs | openai
TTS_PROVIDER=edge
TTS_DEFAULT_VOICE=vi-VN-HoaiMyNeural
ELEVENLABS_API_KEY=
# OPENAI_API_KEY reused for openai-tts

# ----- Subtitle fallback -----
# Whisper model used when TTS provider has no word timings (e.g. gtts).
# Options: tiny | base | small | medium
WHISPER_MODEL=base
WHISPER_DEVICE=cpu
WHISPER_LANGUAGE=vi

# ----- Hyperframes -----
HYPERFRAMES_DIR=../../packages/hyperframes

# ----- Render -----
PLAYWRIGHT_HEADLESS=true
RENDER_FPS=30
RENDER_WIDTH_PORTRAIT=1080
RENDER_HEIGHT_PORTRAIT=1920
RENDER_WIDTH_LANDSCAPE=1920
RENDER_HEIGHT_LANDSCAPE=1080

# ----- Logging -----
LOG_LEVEL=INFO
LOG_JSON=false

# =========================================
# Re-enable when swapping back to Postgres + Celery (Phase 2+)
# =========================================
# DATABASE_URL=postgresql+psycopg://aividforge:aividforge@localhost:5432/aividforge
# REDIS_URL=redis://localhost:6379/0
# STORAGE_BACKEND=local
