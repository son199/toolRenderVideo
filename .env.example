# =========================================
# AIVidForge - Environment configuration
# =========================================
# Copy this file to .env and fill in your values.
# Backend reads these via pydantic-settings.

# ----- Server -----
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
FRONTEND_ORIGIN=http://localhost:5173

# ----- Storage -----
# Phase 1 stores projects as JSON files under this folder
# (storage_dir/projects/<uuid>.json). Postgres comes back in a later sprint.
STORAGE_DIR=../../storage

# ----- LLM (storyboard generator) -----
# Provider: openai | claude | gemini
LLM_PROVIDER=openai

# OpenAI
OPENAI_BASE_URL=http://localhost:20128/v1
OPENAI_API_KEY=sk-63f4a8616fd15031-aflr6o-15b1b521
OPENAI_MODEL=gh/gpt-4.1

# Anthropic / Claude (your gateway)
ANTHROPIC_BASE_URL=http://localhost:20128/v1
ANTHROPIC_API_KEY=sk-63f4a8616fd15031-aflr6o-15b1b521
ANTHROPIC_MODEL=cc/claude-sonnet-4-6

# Google Gemini
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# ----- TTS -----
# Provider: edge | gtts | elevenlabs | openai
# Edge có word_timings native (animation khớp voice). gtts thì cần faster-whisper
# alignment fallback (cài thêm: pip install faster-whisper).
# NOTE: Bing Edge TTS bị proxy công ty chặn → dùng gtts + Whisper alignment.
TTS_PROVIDER=gtts
TTS_DEFAULT_VOICE=vi-VN-HoaiMyNeural
ELEVENLABS_API_KEY=
# OPENAI_API_KEY reused for openai-tts

# ----- Subtitle fallback -----
# Whisper model used when TTS provider has no word timings (e.g. gtts).
# Options: tiny | base | small | medium
WHISPER_MODEL=base
WHISPER_DEVICE=cpu
WHISPER_LANGUAGE=vi

# ----- Voice sync -----
# True → backend tự chạy Whisper forced-alignment khi TTS không trả word_timings.
# Cần: pip install faster-whisper (chỉ khi TTS_PROVIDER != edge/elevenlabs).
TTS_FORCE_ALIGNMENT_FALLBACK=true

# Đặt True NẾU máy nằm sau proxy MITM của công ty và Edge TTS báo SSL cert error.
# ⚠️ Tắt SSL verification cho toàn bộ HTTP/HTTPS calls — chỉ dùng trên mạng tin cậy.
TTS_SSL_VERIFY_DISABLE=true

# ----- Groq STT (cloud Whisper, FREE tier) -----
# Cách lấy key: https://console.groq.com/keys (1 phút đăng ký, không cần thẻ).
# Free tier: ~14400 giây audio/ngày (đủ cho 100+ video/ngày).
# Khi có key, jobs.py sẽ tự dùng Groq để align audio → word_timings chuẩn xác.
GROQ_API_KEY=
GROQ_STT_MODEL=whisper-large-v3-turbo

# ----- Render -----
RENDER_FPS=30

# ----- Logging -----
LOG_LEVEL=INFO
LOG_JSON=false


# Concurrency: 0 = auto (cpu_count - 2, capped at 16). Set thấp hơn nếu máy yếu.
RENDER_CONCURRENCY=0
# Bật True khi máy KHÔNG CÓ GPU rời (office laptop, VPS) — dùng software GL
# (swiftshader), concurrency thấp; render chậm hơn ~30-50% nhưng không crash.
RENDER_LOW_RESOURCE_MODE=false

# =========================================
# Re-enable when swapping back to Postgres + Celery (Phase 2+)
# =========================================
# DATABASE_URL=postgresql+psycopg://aividforge:aividforge@localhost:5432/aividforge
# REDIS_URL=redis://localhost:6379/0
# STORAGE_BACKEND=local
